rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default dynamic deny-all global gate
    match /{document=**} {
      allow read, write: if false;
    }
    
    // --- STANDALONE PRIMITIVES ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    // Global admin list (bootstrapped admin)
    function isGlobalAdmin() {
      return isSignedIn() && request.auth.token.email == 'sasamihajlov709@gmail.com';
    }

    // --- REUSABLE GET HELPERS ---
    function getChat(chatId) {
      return get(/databases/$(database)/documents/chats/$(chatId)).data;
    }
    
    function getUser(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    // Role checks inside a chat
    function isChatMember(chatId, userId) {
      return getChat(chatId).members.hasAny([userId]);
    }
    
    function isChatAdmin(chatId, userId) {
      let chat = getChat(chatId);
      return chat.creatorId == userId || (chat.admins != null && chat.admins.hasAny([userId]));
    }
    
    function isChatModerator(chatId, userId) {
      let chat = getChat(chatId);
      return isChatAdmin(chatId, userId) || (chat.moderatorIds != null && chat.moderatorIds.hasAny([userId]));
    }

    // --- ENTITY VALIDATION HELPERS ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'username', 'email'])
        && data.uid is string && data.uid.size() >= 1 && data.uid.size() <= 128
        && data.displayName is string && data.displayName.size() <= 100
        && data.username is string && data.username.size() <= 50
        && data.email is string && data.email.size() <= 150
        && (data.bio == null || (data.bio is string && data.bio.size() <= 4000))
        && (data.statusMessage == null || (data.statusMessage is string && data.statusMessage.size() <= 1000))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048));
    }
    
    function isValidChat(data) {
      return data.keys().hasAll(['id', 'type', 'creatorId', 'members'])
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.type in ['direct', 'group', 'channel', 'public']
        && data.creatorId is string && data.creatorId.size() <= 128
        && data.members is list && data.members.size() <= 5000;
    }
    
    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'chatId', 'senderId', 'text', 'type', 'createdAt'])
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.chatId is string && data.chatId.size() >= 1 && data.chatId.size() <= 128
        && data.senderId is string && data.senderId.size() >= 1 && data.senderId.size() <= 128
        && data.text is string && data.text.size() <= 10000
        && data.type is string && data.type.size() <= 50
        && data.createdAt is int;
    }
    
    function isValidCall(data) {
      return data.keys().hasAll(['id', 'callerId', 'receiverId', 'status', 'type', 'createdAt'])
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.callerId is string && data.callerId.size() <= 128
        && data.receiverId is string && data.receiverId.size() <= 128
        && data.status is string && data.status.size() <= 50
        && data.type is string && data.type.size() <= 50
        && data.createdAt is int;
    }
    
    function isValidStory(data) {
      return data.keys().hasAll(['id', 'userId', 'mediaUrl', 'createdAt', 'expiresAt'])
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.mediaUrl is string && data.mediaUrl.size() <= 2048
        && data.createdAt is int
        && data.expiresAt is int;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['id', 'reporterId', 'reportedUserId', 'reason', 'createdAt'])
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.reporterId is string && data.reporterId.size() <= 128
        && data.reportedUserId is string && data.reportedUserId.size() <= 128
        && data.reason is string && data.reason.size() <= 2000
        && data.createdAt is int;
    }

    function isValidInvite(data) {
      return data.keys().hasAll(['id', 'chatId', 'creatorId', 'createdAt', 'isRevoked'])
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.chatId is string && data.chatId.size() <= 128
        && data.creatorId is string && data.creatorId.size() <= 128
        && data.createdAt is int
        && data.isRevoked is bool;
    }

    function isValidJoinRequest(data) {
      return data.keys().hasAll(['id', 'userId', 'chatId', 'status', 'createdAt'])
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.chatId is string && data.chatId.size() <= 128
        && data.status is string && data.status.size() <= 50
        && data.createdAt is int;
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['id', 'actorId', 'actorName', 'action', 'details', 'timestamp'])
        && data.id is string && data.id.size() >= 1 && data.id.size() <= 128
        && data.actorId is string && data.actorId.size() <= 128
        && data.actorName is string && data.actorName.size() <= 100
        && data.action is string && data.action.size() <= 100
        && data.details is string && data.details.size() <= 5000
        && data.timestamp is int;
    }

    // Check if user is being blocked by target
    function isBlockedBy(targetUid, authUid) {
      let targetDoc = getUser(targetUid);
      return targetDoc.blockedUsers != null && targetDoc.blockedUsers.hasAny([authUid]);
    }

    // --- CORES ---
    
    // --- Users Collection ---
    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming()) && !incoming().keys().hasAny(['role', 'isAdmin']);
      allow update: if isOwner(userId) && isValidUser(incoming()) && !incoming().keys().hasAny(['role', 'isAdmin']);
      allow delete: if false; // Admin deletion only
    }

    // --- Chats Collection ---
    match /chats/{chatId} {
      allow get: if isSignedIn() && isValidId(chatId) && (
        resource.data.type == 'public' || 
        resource.data.members.hasAny([request.auth.uid])
      );
      allow list: if isSignedIn() && (
        resource.data.type == 'public' || 
        resource.data.members.hasAny([request.auth.uid])
      );
      allow create: if isSignedIn() && isValidId(chatId) && isValidChat(incoming()) && incoming().creatorId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(chatId) && (
        // Creator/Admins can edit properties (except immutables like creatorId)
        (isChatAdmin(chatId, request.auth.uid) && !incoming().diff(existing()).affectedKeys().hasAny(['creatorId'])) ||
        // Regular members can join/leave or modify personal fields (like pin status, archived, mute, drafts)
        (existing().members.hasAny([request.auth.uid]) && incoming().diff(existing()).affectedKeys().hasOnly([
          'pinnedIds', 'archivedIds', 'muteIds', 'unreadCounts', 'typing', 'drafts', 'editingDrafts'
        ])) ||
        // Joining a public chat or private via valid requests/invites
        (!existing().members.hasAny([request.auth.uid]) && incoming().members.hasAny([request.auth.uid]) && (
          existing().type == 'public' || 
          incoming().diff(existing()).affectedKeys().hasOnly(['members', 'unreadCounts'])
        ))
      );
      allow delete: if isSignedIn() && isValidId(chatId) && isChatAdmin(chatId, request.auth.uid);
    }

    // --- Messages Collection ---
    match /messages/{messageId} {
      allow get: if isSignedIn() && isValidId(messageId) && (
        getChat(resource.data.chatId).type == 'public' || 
        isChatMember(resource.data.chatId, request.auth.uid)
      );
      allow list: if isSignedIn() && (
        getChat(resource.data.chatId).type == 'public' || 
        isChatMember(resource.data.chatId, request.auth.uid)
      );
      allow create: if isSignedIn() && isValidId(messageId) && isValidMessage(incoming()) 
        && incoming().senderId == request.auth.uid 
        && isChatMember(incoming().chatId, request.auth.uid)
        && (getChat(incoming().chatId).restrictedIds == null || !getChat(incoming().chatId).restrictedIds.hasAny([request.auth.uid]));
      allow update: if isSignedIn() && isValidId(messageId) && (
        // Message author can edit their message text
        (resource.data.senderId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['text', 'updatedAt', 'editHistory'])) ||
        // Other members can add/remove reactions under their own uid slot, or append themselves to readBy
        (isChatMember(resource.data.chatId, request.auth.uid) && incoming().diff(existing()).affectedKeys().hasOnly(['reactions', 'readBy', 'poll']))
      );
      allow delete: if isSignedIn() && isValidId(messageId) && (
        resource.data.senderId == request.auth.uid || 
        isChatAdmin(resource.data.chatId, request.auth.uid)
      );
    }

    // --- Calls Collection ---
    match /calls/{callId} {
      allow get: if isSignedIn() && isValidId(callId) && (
        resource.data.callerId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow list: if isSignedIn() && (
        resource.data.callerId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isSignedIn() && isValidId(callId) && isValidCall(incoming()) 
        && incoming().callerId == request.auth.uid
        && !isBlockedBy(incoming().receiverId, request.auth.uid); // Block check
      allow update: if isSignedIn() && isValidId(callId) && (
        resource.data.callerId == request.auth.uid || 
        resource.data.receiverId == request.auth.uid
      );
      allow delete: if isSignedIn() && isValidId(callId) && (
        resource.data.callerId == request.auth.uid || 
        isGlobalAdmin()
      );
      
      match /signalData/{signalId} {
        allow read, write: if isSignedIn(); 
      }
    }

    // --- Stories Collection ---
    match /stories/{storyId} {
      allow get: if isSignedIn() && isValidId(storyId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(storyId) && isValidStory(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(storyId) && (
        resource.data.userId == request.auth.uid ||
        // Views or reaction edits by other users
        incoming().diff(existing()).affectedKeys().hasOnly(['views', 'reactions'])
      );
      allow delete: if isSignedIn() && isValidId(storyId) && (resource.data.userId == request.auth.uid || isGlobalAdmin());
    }

    // --- Reports Collection ---
    match /reports/{reportId} {
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming()) && incoming().reporterId == request.auth.uid;
      allow read, update, delete: if isGlobalAdmin();
    }

    // --- Invites Collection ---
    match /invites/{inviteId} {
      allow get: if isSignedIn() && isValidId(inviteId);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(inviteId) && isValidInvite(incoming()) && isChatAdmin(incoming().chatId, request.auth.uid);
      allow update: if isSignedIn() && isValidId(inviteId) && (
        isChatAdmin(resource.data.chatId, request.auth.uid) ||
        // Increment usage count during signups
        incoming().diff(existing()).affectedKeys().hasOnly(['usageCount', 'usageLimit'])
      );
      allow delete: if isSignedIn() && isValidId(inviteId) && isChatAdmin(resource.data.chatId, request.auth.uid);
    }

    // --- Join Requests Collection ---
    match /joinRequests/{requestId} {
      allow get: if isSignedIn() && isValidId(requestId) && (
        resource.data.userId == request.auth.uid || 
        isChatAdmin(resource.data.chatId, request.auth.uid)
      );
      allow list: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isChatAdmin(resource.data.chatId, request.auth.uid)
      );
      allow create: if isSignedIn() && isValidId(requestId) && isValidJoinRequest(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(requestId) && isChatAdmin(resource.data.chatId, request.auth.uid);
      allow delete: if isSignedIn() && isValidId(requestId) && (
        resource.data.userId == request.auth.uid || 
        isChatAdmin(resource.data.chatId, request.auth.uid)
      );
    }

    // --- Audit Logs Collection ---
    match /auditLogs/{logId} {
      allow create: if isSignedIn() && isValidId(logId) && isValidAuditLog(incoming()) && incoming().actorId == request.auth.uid;
      allow read: if isGlobalAdmin();
      allow update, delete: if false; // Audit logs must be completely immutable
    }
  }
}
